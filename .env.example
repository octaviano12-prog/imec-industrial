PORT=3000
HOST=0.0.0.0
NODE_ENV=production
SESSION_SECRET=troque-por-uma-chave-segura-longa

# Use mysql na publicacao. O modo file serve apenas para demonstracao local.
DATA_DRIVER=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=imec_site
