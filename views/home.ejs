<%- include("partials/head") %>
<%- include("partials/header") %>

    <main id="main" class="premium-home">
      <section class="industrial-hero">
        <div class="industrial-hero-media">
          <% if (site.home.heroVideo) { %>
            <video autoplay muted loop playsinline src="<%= site.home.heroVideo %>"></video>
          <% } else { %>
            <img src="<%= site.home.heroMedia %>" alt="">
          <% } %>
        </div>
        <div class="industrial-orbit" aria-hidden="true"></div>
        <div class="shell industrial-hero-content">
          <p class="eyebrow reveal"><%= site.home.eyebrow %></p>
          <h1 class="reveal">Engenharia industrial<br>de <em>alta performance</em></h1>
          <p class="industrial-lead reveal"><%= site.home.subtitle %></p>
          <div class="industrial-actions reveal">
            <a class="pill pill-red" href="/contato">Solicitar orçamento</a>
            <a class="pill pill-line" href="/reformas-servicos">Conhecer serviços</a>
          </div>
        </div>
        <div class="shell industrial-qualities">
          <% [
            ["Segurança e qualidade", "Processos certificados e foco em segurança industrial"],
            ["Engenharia aplicada", "Soluções personalizadas para máxima eficiência"],
            ["Experiência comprovada", "Atuação sólida em usinas e indústrias de todo o Brasil"],
            ["Entrega com excelência", "Compromisso com prazos, desempenho e resultados"]
          ].forEach((item) => { %>
            <article class="reveal"><span></span><div><h2><%= item[0] %></h2><p><%= item[1] %></p></div></article>
          <% }) %>
        </div>
      </section>

      <section class="industrial-stats">
        <div class="shell stat-panel reveal">
          <% [
            ["+100", "Usinas atendidas", "Atuação em todo o Brasil"],
            ["+25", "Anos de história", "Tradição, confiança e solidez"],
            ["+500", "Projetos executados", "Em diferentes segmentos industriais"],
            ["5.000m²", "Área fabril", "Estrutura completa para grandes fabricações"]
          ].forEach((item) => { %>
            <article>
              <i></i>
              <strong><%= item[0] %></strong>
              <b><%= item[1] %></b>
              <p><%= item[2] %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="industrial-reference">
        <div class="shell reference-grid">
          <div class="reference-copy reveal">
            <p class="eyebrow">Por que a IMEC</p>
            <h2>É referência<br>em engenharia?</h2>
            <p>Combinamos engenharia, tecnologia e mão de obra especializada para entregar soluções industriais completas, seguras e eficientes.</p>
            <a class="outline-action" href="/empresa">Conheça mais sobre a IMEC <span>+</span></a>
          </div>
          <div class="reference-services reveal">
            <% [
              ["Fabricação industrial", "Equipamentos e estruturas metálicas de alta complexidade."],
              ["Reformas e retrofit", "Modernização e aumento de vida útil de equipamentos e plantas."],
              ["Montagem industrial", "Montagem eletromecânica com segurança e precisão."],
              ["Caldeiraria pesada", "Serviços especializados em chapas grossas e estruturas robustas."],
              ["Engenharia e projetos", "Desenvolvimento técnico e soluções personalizadas."],
              ["Manutenção industrial", "Paradas programadas, manutenção preventiva e corretiva."]
            ].forEach((service) => { %>
              <article><span></span><h3><%= service[0] %></h3><p><%= service[1] %></p></article>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="industrial-projects">
        <div class="shell project-heading reveal">
          <div>
            <p class="eyebrow">Projetos que</p>
            <h2>Geram <em>resultados</em></h2>
          </div>
          <p>Atuamos em projetos desafiadores que exigem precisão, tecnologia e compromisso. Cada entrega é feita para impulsionar a produtividade e a eficiência da sua operação.</p>
        </div>
        <div class="shell project-showcase">
          <% [
            [site.home.processMedia, "Reforma de caldeiras", "Usina Delta - SP"],
            [site.home.featureReformMedia, "Trocadores de calor", "Usina Ipê - PR"],
            [site.home.heroMedia, "Montagem industrial", "Usina Santa Clara - GO"],
            [site.home.featureManufacturingMedia, "Fabricação especial", "Usina Vale do Sol - MG"]
          ].forEach((card) => { %>
            <article class="project-card reveal">
              <img src="<%= card[0] %>" alt="<%= card[1] %>">
              <div><h3><%= card[1] %></h3><p><%= card[2] %></p></div>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="industrial-final-cta">
        <div class="shell final-cta-grid">
          <h2>Pronto para sua próxima<br>parada industrial?</h2>
          <p>Entre em contato com nosso time de engenharia e descubra como a IMEC pode transformar sua operação com eficiência e segurança.</p>
          <a class="pill pill-red" href="/contato">Falar com a engenharia</a>
        </div>
      </section>
    </main>

<%- include("partials/footer") %>
